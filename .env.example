# Copy this to .env and fill in your values
GROK_API_KEY=your-grok-api-key-here

# Optional overrides
GROK_MODEL=llama-3.3-70b-versatile
GROK_BASE_URL=https://api.groq.com/openai/v1
RATE_LIMIT_PER_HOUR=50
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
SESSION_IDLE_TIMEOUT_MINUTES=60

# SSO (Trusted header)
SSO_HEADER_USERNAME=
SSO_AUTO_PROVISION=true
SSO_ADMIN_USERS=

# SMTP for sending temporary credentials to new users
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Optional: use SendGrid API (HTTPS) if SMTP ports are blocked
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# One-time admin bootstrap (recommended: set once, then clear password)
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=

# Security hardening (keep false in production)
ALLOW_DANGEROUS_DESERIALIZATION=false
ENABLE_RERANKER=false
# Embeddings run locally via HuggingFace (no API key needed)

# Retrieval robustness
ENABLE_HYBRID_SEARCH=true
HYBRID_BM25_WEIGHT=0.35
REQUIRE_CITATIONS=true
ENABLE_VERIFICATION_PASS=false
CIRCUIT_BREAKER_FAILURES=4
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# Data retention
DATA_RETENTION_DAYS=180
